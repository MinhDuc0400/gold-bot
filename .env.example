# ===== TELEGRAM BOT =====
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Your personal Telegram user ID
# Get from @userinfobot on Telegram
TELEGRAM_CHAT_ID=123456789

# ===== GOLD API =====
# Get free key from https://www.goldapi.io
GOLDAPI_KEY=goldapi-xxxxxxxxxxxxxxxxxxxx-io

# ===== EXCHANGE RATE =====
# USD to VND exchange rate (update daily if needed)
# Current: 1 USD = 26,500 VND
USD_TO_VND_RATE=26500

# ===== SCHEDULING =====
# Cron format: minute hour day month weekday
# 0 8 * * * = 08:00 AM every day
CRON_TIME=0 8 * * *

# Timezone for cron (IANA format)
# Vietnam: Asia/Ho_Chi_Minh
TIMEZONE=Asia/Ho_Chi_Minh

# ===== LOGGING =====
# Log level: debug, info, warn, error
LOG_LEVEL=info

# Log file path
LOG_FILE=./logs/bot.log

# ===== SCRAPING =====
# Timeout for page load (ms)
SCRAPE_TIMEOUT=15000

# Run browser in headless mode
BROWSER_HEADLESS=true

# ===== DEVELOPMENT =====
# Development mode for extra logging
DEV_MODE=false
